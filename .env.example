# Copy to .env and fill in real values for local docker-compose runs.
# .env is gitignored - never commit real secrets.

# Used to sign/verify JWTs issued by the api service. docker-compose falls back
# to "dev-secret-change-me" if this is unset, which is fine for local dev only.
JWT_SECRET=dev-secret-change-me

# Overrides the default docker-compose DATABASE_URL if you point services at a
# different Postgres instance.
DATABASE_URL=postgres://taskflow:taskflow@postgres:5432/taskflow?sslmode=disable

# Comma-separated browser origins allowed to call the API (needed by the web
# dashboard in web/, which runs on a different origin than the API). Defaults
# to the Vite dev server's origin; set to your deployed dashboard's origin in
# production instead of "*".
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Postgres connection pool size (per process - api, worker, and scheduler each
# open their own pool). Left unset, pgx silently defaults to max(4, NumCPU),
# which shrinks unexpectedly on CPU-constrained containers. Raise these if you
# see pool-exhaustion errors under load.
DB_MAX_CONNS=10
DB_MIN_CONNS=2
